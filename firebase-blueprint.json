{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["USER", "ADMIN", "SUPER_ADMIN"] },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED", "CANCEL"] },
        "currency": { "type": "string" },
        "language": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income or expense record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["INCOME", "EXPENSE", "BUDGET"] },
        "amount": { "type": "number" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "date"]
    },
    "Category": {
      "title": "Category",
      "description": "Transaction category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["INCOME", "EXPENSE", "BUDGET"] },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Budget goal for a category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "categoryType": { "type": "string", "enum": ["INCOME", "EXPENSE", "BUDGET"] },
        "amount": { "type": "number" },
        "period": { "type": "string", "enum": ["MONTHLY", "YEARLY"] },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "categoryId", "amount", "period"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Loan tracking record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "borrowerName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "amount": { "type": "number" },
        "givenDate": { "type": "string", "format": "date" },
        "expectedReturnDate": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Partially Paid", "Paid"] },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "borrowerName", "amount", "givenDate", "expectedReturnDate", "status"]
    },
    "LoanRepayment": {
      "title": "LoanRepayment",
      "description": "Repayment of a loan",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "loanId": { "type": "string" },
        "repaymentAmount": { "type": "number" },
        "repaymentDate": { "type": "string" , "format": "date" },
        "note": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "loanId", "repaymentAmount", "repaymentDate"]
    },
    "Client": {
      "title": "Client",
      "description": "Developer's client record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "companyName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "whatsAppNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "balance": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "balance"]
    },
    "ClientLedger": {
      "title": "ClientLedger",
      "description": "Ledger entry tracking client balances",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["Project Charge", "Subscription Charge", "Payment Received", "Adjustment", "Refund"] },
        "description": { "type": "string" },
        "debit": { "type": "number" },
        "credit": { "type": "number" },
        "runningBalance": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientId", "date", "type", "description", "debit", "credit", "runningBalance"]
    },
    "Project": {
      "title": "Project",
      "description": "Client custom software project tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "projectName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "advanceAmount": { "type": "number" },
        "dueAmount": { "type": "number" },
        "deliveryDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["In Progress", "Completed", "On Hold", "Cancelled", "Not Started"] },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientId", "clientName", "projectName", "totalAmount", "advanceAmount", "dueAmount", "deliveryDate", "status"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "POS or SaaS active software subscription tracker",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "productName": { "type": "string" },
        "planName": { "type": "string" },
        "monthlyFee": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "renewalDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Cancelled", "Past Due"] },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientId", "clientName", "productName", "planName", "monthlyFee", "startDate", "renewalDate", "status"]
    },
    "Receivable": {
      "title": "Receivable",
      "description": "A payment receivable due invoice entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "amount": { "type": "number" },
        "invoiceNumber": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Partial", "Paid"] },
        "amountPaid": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientId", "clientName", "amount", "dueDate", "description", "status", "amountPaid"]
    },
    "PaymentCollection": {
      "title": "PaymentCollection",
      "description": "Incoming cash payments collected from clients",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "receivableId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentDate": { "type": "string", "format": "date" },
        "paymentMethod": { "type": "string", "enum": ["Cash", "Bank Transfer", "Mobile Banking", "Check", "SaaS Gateway", "Other"] },
        "transactionReference": { "type": "string" },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientId", "clientName", "amount", "paymentDate", "paymentMethod"]
    },
    "Quotation": {
      "title": "Quotation",
      "description": "A quotation for project or service",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "clientId": { "type": "string" },
        "quotationNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Sent", "Accepted", "Rejected", "Expired"] },
        "totalAmount": { "type": "number" },
        "quotationDate": { "type": "string", "format": "date" },
        "validUntilDate": { "type": "string", "format": "date" },
        "projectName": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "clientId", "quotationNumber", "status", "totalAmount"]
    },
    "QuotationItem": {
      "title": "QuotationItem",
      "description": "A line item for a quotation",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "quotationId": { "type": "string" },
        "itemName": { "type": "string" },
        "description": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" }
      },
      "required": ["ownerId", "quotationId", "itemName", "quantity", "unitPrice", "total"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction records"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Transaction categories"
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Budget definitions"
    },
    "/loans/{loanId}": {
      "schema": "Loan",
      "description": "Lent money records"
    },
    "/loan_repayments/{repaymentId}": {
      "schema": "LoanRepayment",
      "description": "Repayments for lent money"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Developer client records"
    },
    "/client_ledgers/{ledgerId}": {
      "schema": "ClientLedger",
      "description": "Client standard ledgers entries"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Active client project records"
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "SaaS and POS subscriptions tracker"
    },
    "/receivables/{receivableId}": {
      "schema": "Receivable",
      "description": "Client invoice or payments due tracking"
    },
    "/payments/{paymentId}": {
      "schema": "PaymentCollection",
      "description": "Client cash collection entries"
    },
    "/quotations/{quotationId}": {
      "schema": "Quotation",
      "description": "Quotation details"
    },
    "/quotation_items/{itemId}": {
      "schema": "QuotationItem",
      "description": "Line items of quotations"
    }
  }
}
