rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - email: string (required)
    //   - name: string
    //   - role: string (USER, ADMIN, SUPER_ADMIN)
    //   - status: string (PENDING, APPROVED, REJECTED, CANCEL)
    //   - currency: string
    //   - language: string
    //   - phoneNumber: string
    //   - created_at: timestamp
    //   - deleted_at: timestamp
    //
    // Collection: transactions
    // Fields:
    //   - userId: string (required)
    //   - type: string (INCOME, EXPENSE)
    //   - amount: number
    //   - categoryId: string
    //   - categoryName: string
    //   - date: string
    //   - description: string
    //   - status: string (ACTIVE, INACTIVE)
    //   - created_at: timestamp
    //   - deleted_at: timestamp
    //
    // Collection: categories
    // Fields:
    //   - userId: string (null for global)
    //   - name: string
    //   - type: string (INCOME, EXPENSE)
    //   - deleted_at: timestamp
    //
    // Collection: budgets
    // Fields:
    //   - userId: string
    //   - categoryId: string
    //   - categoryName: string
    //   - categoryType: string (INCOME, EXPENSE)
    //   - amount: number
    //   - period: string (MONTHLY, YEARLY)
    //   - created_at: timestamp
    //   - deleted_at: timestamp
    //
    // Collection: recurring_transactions
    // Fields:
    //   - userId: string
    //   - type: string (INCOME, EXPENSE)
    //   - amount: number
    //   - categoryId: string
    //   - categoryName: string
    //   - frequency: string (DAILY, WEEKLY, MONTHLY, YEARLY)
    //   - startDate: string
    //   - description: string
    //   - active: boolean
    //   - created_at: timestamp
    //   - deleted_at: timestamp
    //
    // Collection: activity_logs
    // Fields:
    //   - userId: string
    //   - userName: string
    //   - userEmail: string
    //   - action: string
    //   - details: string
    //   - created_at: timestamp
    //
    // Collection: role_permissions
    // Fields:
    //   - role: string
    //   - permissions: list<string>
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN'] ||
          (request.auth.token.email == "shshohagh4@gmail.com" && request.auth.token.email_verified == true));
    }

    function isApproved() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'APPROVED';
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['id', 'email', 'name', 'role', 'status', 'currency', 'language', 'permissions', 'created_at', 'deleted_at', 'updated_at', 'phoneNumber']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 255 &&
             data.name is string && data.name.size() < 100 &&
             data.role in ['USER', 'ADMIN', 'SUPER_ADMIN'] &&
             data.status in ['PENDING', 'APPROVED', 'REJECTED', 'CANCEL'];
    }

    function isValidTransaction(data) {
      return data.keys().hasOnly(['userId', 'type', 'amount', 'categoryId', 'categoryName', 'date', 'description', 'status', 'created_at', 'deleted_at', 'isDemo']) &&
             data.userId == request.auth.uid &&
             data.type in ['INCOME', 'EXPENSE', 'BUDGET'] &&
             data.amount is number &&
             data.date is string &&
             data.description is string && data.description.size() < 500;
    }

    function isValidCategory(data) {
      return data.keys().hasOnly(['userId', 'name', 'type', 'deleted_at', 'isDemo']) &&
             ((data.userId == null && isAdmin()) || data.userId == request.auth.uid) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.type in ['INCOME', 'EXPENSE', 'BUDGET'];
    }

    function isValidBudget(data) {
      return data.keys().hasOnly(['userId', 'categoryId', 'categoryName', 'categoryType', 'amount', 'period', 'created_at', 'deleted_at', 'updated_at', 'isDemo']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.period in ['MONTHLY', 'YEARLY'];
    }

    function isValidRecurring(data) {
      return data.keys().hasOnly(['userId', 'type', 'amount', 'categoryId', 'categoryName', 'frequency', 'startDate', 'nextDate', 'description', 'active', 'created_at', 'deleted_at', 'updated_at', 'isDemo']) &&
             data.userId == request.auth.uid &&
             data.type in ['INCOME', 'EXPENSE', 'BUDGET'] &&
             data.amount is number &&
             data.frequency in ['DAILY', 'WEEKLY', 'MONTHLY', 'YEARLY'] &&
             data.active is bool;
    }

    function isValidActivity(data) {
      return data.keys().hasOnly(['userId', 'userName', 'userEmail', 'action', 'details', 'created_at']) &&
             data.userId == request.auth.uid &&
             data.action is string &&
             data.details is string && data.details.size() < 1000;
    }

    function isValidLoan(data) {
      return data.userId == request.auth.uid &&
             data.borrowerName is string && data.borrowerName.size() > 0 && data.borrowerName.size() < 100 &&
             data.amount is number &&
             data.givenDate is string &&
             data.expectedReturnDate is string &&
             data.status in ['Pending', 'Partially Paid', 'Paid'] &&
             (data.borrowerId is string || !('borrowerId' in data)) &&
             (data.mobileNumber is string || !('mobileNumber' in data)) &&
             (data.notes is string || !('notes' in data));
    }

    function isValidRepayment(data) {
      return data.keys().hasOverlapping(['userId', 'loanId', 'repaymentAmount', 'repaymentDate']) &&
             data.userId == request.auth.uid &&
             data.loanId is string && data.loanId.size() > 0 &&
             data.repaymentAmount is number &&
             data.repaymentDate is string;
    }

    function isValidClient(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 &&
             data.balance is number;
    }

    function isValidClientLedger(data) {
      return data.userId == request.auth.uid &&
             data.clientId is string &&
             data.type in ["Project Charge", "Subscription Charge", "Payment Received", "Adjustment", "Refund"];
    }

    function isValidProject(data) {
      return data.userId == request.auth.uid &&
             data.clientId is string &&
             data.projectName is string && data.projectName.size() > 0 &&
             data.status in ["In Progress", "Completed", "On Hold", "Cancelled", "Not Started"];
    }

    function isValidSubscription(data) {
      return data.userId == request.auth.uid &&
             data.clientId is string &&
             data.productName is string &&
             data.status in ["Active", "Inactive", "Cancelled", "Past Due"];
    }

    function isValidReceivable(data) {
      return data.userId == request.auth.uid &&
             data.clientId is string &&
             data.amount is number &&
             data.status in ["Pending", "Partial", "Paid"];
    }

    function isValidPayment(data) {
      return data.userId == request.auth.uid &&
             data.clientId is string &&
             data.amount is number &&
             data.paymentMethod in ["Cash", "Bank Transfer", "Mobile Banking", "Check", "SaaS Gateway", "Other"];
    }

    function isValidBorrower(data) {
      return data.ownerId == request.auth.uid &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.status in ["Active", "Inactive"];
    }

    function isValidQuotation(data) {
      return data.ownerId == request.auth.uid &&
             data.clientId is string &&
             data.quotationNumber is string &&
             data.status in ["Draft", "Sent", "Accepted", "Rejected", "Expired"] &&
             data.totalAmount is number;
    }

    function isValidQuotationItem(data) {
      return data.ownerId == request.auth.uid &&
             data.quotationId is string &&
             data.itemName is string &&
             data.quantity is number &&
             data.unitPrice is number &&
             data.total is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow delete: if isAuthenticated() && (isOwner(userId) || isAdmin() || resource.data.email == request.auth.token.email);
    }

    match /transactions/{transactionId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidTransaction(request.resource.data);
      allow update: if isApproved() && isValidTransaction(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /categories/{categoryId} {
      allow read: if isApproved() || isAdmin();
      allow create: if isApproved() && isValidCategory(request.resource.data);
      allow update: if isApproved() && isValidCategory(request.resource.data) && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isApproved() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /budgets/{budgetId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidBudget(request.resource.data);
      allow update: if isApproved() && isValidBudget(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /recurring_transactions/{rtId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidRecurring(request.resource.data);
      allow update: if isApproved() && isValidRecurring(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /activity_logs/{logId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidActivity(request.resource.data);
    }

    match /loans/{loanId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidLoan(request.resource.data);
      allow update: if isApproved() && isValidLoan(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /loan_repayments/{repaymentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidRepayment(request.resource.data);
      allow update: if isApproved() && isValidRepayment(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /role_permissions/{role} {
      allow read: if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidClient(request.resource.data);
      allow update: if isApproved() && isValidClient(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /client_ledgers/{ledgerId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidClientLedger(request.resource.data);
      allow update: if isApproved() && isValidClientLedger(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidProject(request.resource.data);
      allow update: if isApproved() && isValidProject(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidSubscription(request.resource.data);
      allow update: if isApproved() && isValidSubscription(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /receivables/{receivableId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidReceivable(request.resource.data);
      allow update: if isApproved() && isValidReceivable(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /payments/{paymentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isApproved() && isValidPayment(request.resource.data);
      allow update: if isApproved() && isValidPayment(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isApproved() && (isDocOwner() || isAdmin());
    }

    match /borrowers/{borrowerId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isApproved() && isValidBorrower(request.resource.data);
      allow update: if isApproved() && isValidBorrower(request.resource.data) && ((isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin());
      allow delete: if isApproved() && ((isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin());
    }

    match /quotations/{quotationId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isApproved() && isValidQuotation(request.resource.data);
      allow update: if isApproved() && isValidQuotation(request.resource.data) && ((isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin());
      allow delete: if isApproved() && ((isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin());
    }

    match /quotation_items/{itemId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isApproved() && isValidQuotationItem(request.resource.data);
      allow update: if isApproved() && isValidQuotationItem(request.resource.data) && ((isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin());
      allow delete: if isApproved() && ((isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin());
    }
  }
}
